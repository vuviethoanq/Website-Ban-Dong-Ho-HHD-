<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site.master.cs" Inherits="WBDH_BTL.Site" %>

<!DOCTYPE html>
<html>
<head runat="server">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HHD TIME - Đồng hồ Thụy Sỹ Chính Hãng</title>
    <link rel="stylesheet" href="Styles/Master.css" />
</head>
<body>
    <form id="form1" runat="server" MaintainScrollPositionOnPostBack="true">

        <!-- ========== HEADER ========== -->
        <div class="dau-trang">
