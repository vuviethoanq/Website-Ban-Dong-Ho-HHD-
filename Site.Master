            <div class="o-tim-kiem">
                <asp:TextBox ID="txtTimKiem" runat="server" placeholder="Nhập tên sản phẩm..." CssClass="txt-timkiem" />
                <asp:Button ID="btnTimKiem" runat="server" Text="Tìm kiếm" CssClass="btn-timkiem" OnClick="btnTimKiem_Click" />
            </div>

            <div class="thong-tin">
                <span>GIỜ LÀM VIỆC: 8H30 - 21H30</span>
                <span class="so-dien-thoai">SĐT: 0987779999</span>
 <asp:HyperLink ID="lnkGioHang" runat="server" NavigateUrl="GioHang.aspx" CssClass="cart">
    🛒
    <asp:Label ID="lblCartCount" runat="server" Text="0" CssClass="cart-count"></asp:Label>
</asp:HyperLink>

                <asp:HyperLink ID="lnkDangNhap" runat="server" NavigateUrl="DangNhap.aspx" CssClass="nut-dang-ky">ĐĂNG NHẬP</asp:HyperLink>
                <asp:LinkButton ID="btnTaiKhoan" runat="server" Text="👤" CssClass="nut-tai-khoan" Visible="false" OnClick="btnTaiKhoan_Click"></asp:LinkButton>
            </div>
        </div>

